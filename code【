def data_preprocessing_pipeline(liquid_path, solid_path, output_dir):
    """""""""""""""""""""""""""""""""
    第一阶段：多源异构数据获取、时空对齐、异常值处理与缺失值重构
    """""""""""""""""""""""""""""""""
    print("=" * 60)
    print("第一阶段：多源异构数据预处理与时空对齐")
    print("=" * 60)

    # 确保输出文件夹存在
    os.makedirs(output_dir, exist_ok=True)

    print("1. 正在读取原始液相与固相工业数据...")
    liquid_df = pd.read_csv(liquid_path, encoding='gb18030', encoding_errors='ignore', on_bad_lines='skip',
                            low_memory=False)
    solid_df = pd.read_csv(solid_path, encoding='gb18030', encoding_errors='ignore', on_bad_lines='skip',
                           low_memory=False)

    # 打印固液原始数据结构
    print(f"  -> [结构监控] 原始液相数据结构: {liquid_df.shape[0]} 行, {liquid_df.shape[1]} 列")
    print(f"  -> [结构监控] 原始固相数据结构: {solid_df.shape[0]} 行, {solid_df.shape[1]} 列\n")


    # 强制去除列名前后隐藏的空格
    liquid_df.columns = liquid_df.columns.str.strip()
    solid_df.columns = solid_df.columns.str.strip()

    # 依据《各指标属性》提取涵盖液相与固相的全面特征变量（共22个）
    liquid_cols = ['datatime', 'na2ok_value', 'nc_value', 'nc_nt_value', 'al2o3_value',
                   'solid_content_value', 'fineness_160_value', 'fineness_100_value', 'ak_value', 'na2ot_value']
    solid_cols = ['datatime', 'al2o3_value', 'sio2_value', 'fe2o3_value', 'tio2_value',
                  'na2o_value', 'a_s_value', 'c_s_value', 'n_s_value', 'adhesive_water_value', 'ca_o_value', 'st_value']

    # 过滤掉实际数据中可能不存在的列（防御机制）
    liquid_cols = [col for col in liquid_cols if col in liquid_df.columns]
    solid_cols = [col for col in solid_cols if col in solid_df.columns]

    # 重命名冲突的列名
    liquid_df = liquid_df[liquid_cols].rename(columns={'al2o3_value': 'al2o3_liquid'})
    solid_df = solid_df[solid_cols].rename(columns={'al2o3_value': 'al2o3_solid'})

    features_liquid = [col for col in liquid_df.columns if col != 'datatime']
    features_solid = [col for col in solid_df.columns if col != 'datatime']

    # 强制将所有特征转换为数值类型，无法转换的脏字符变为 NaN
    for col in features_liquid:
        liquid_df[col] = pd.to_numeric(liquid_df[col], errors='coerce')
    for col in features_solid:
        solid_df[col] = pd.to_numeric(solid_df[col], errors='coerce')

    print("2. 正在进行检测时间匹配与数据融合...")
    liquid_df['datatime'] = pd.to_datetime(liquid_df['datatime'])
    solid_df['datatime'] = pd.to_datetime(solid_df['datatime'])

    # 将同一时间点（如I、II、III组）的数据取算术平均，统一时间戳
    liquid_df = liquid_df.groupby('datatime').mean()
    solid_df = solid_df.groupby('datatime').mean()

    # 【新增改动 2：打印同时间戳去重后的数据结构】
    print(f"  -> [结构监控] 均值去重后液相结构: {liquid_df.shape[0]} 行, {liquid_df.shape[1]} 列")
    print(f"  -> [结构监控] 均值去重后固相结构: {solid_df.shape[0]} 行, {solid_df.shape[1]} 列")

    # 采用外联(outer join)保留所有高低频时间点数据
    merged_df = pd.merge(liquid_df, solid_df, left_index=True, right_index=True, how='outer')
    merged_df = merged_df.sort_index()

    # 【新增改动 3：打印固液外联融合后的最终数据结构】
    print(f"  -> [结构监控] 固液数据融合后最终结构: {merged_df.shape[0]} 行, {merged_df.shape[1]} 列")

    # 【数据变动输出 1：原始融合数据】
    step1_path = os.path.join(output_dir, 'Step1_Raw_Merged.csv')
    merged_df.to_csv(step1_path)
    print(f"  -> [输出 1] 原始时序融合完成！快照已保存至: Step1_Raw_Merged.csv\n")

    features = features_liquid + features_solid

    print("3. 正在执行基于3σ准则（拉依达检验）的脉冲噪声与飞点检测...")

    total_outliers = 0  # 记录全局发现的飞点总数
    total_data_points = 0  # 记录全局有效的观测值总数

    for col in features:
        if col in merged_df.columns:
            # 统计该特征当前非空的有效数据个数
            valid_count = merged_df[col].notna().sum()
            total_data_points += valid_count

            if valid_count > 0:
                mean = merged_df[col].mean()
                std = merged_df[col].std()

                # 识别满足 |x - μ| > 3σ 的异常跳变点
                outliers = np.abs(merged_df[col] - mean) > 3 * std
                outlier_count = outliers.sum()

                if outlier_count > 0:
                    outlier_rate = (outlier_count / valid_count) * 100
                    print(f"    - [检测日志] 特征 '{col}': 捕获并剔除飞点 {outlier_count} 个, 发生率: {outlier_rate:.2f}%")

                total_outliers += outlier_count

                # 将异常跳变点置为 NaN，等待后续平滑处理算法进行重构
                merged_df.loc[outliers, col] = np.nan

    if total_data_points > 0:
        overall_rate = (total_outliers / total_data_points) * 100
        print(f"  -> [统计] 3σ清洗完成！全局共计剔除脉冲噪声 {total_outliers} 个，整体异常发生率: {overall_rate:.2f}%")

    # 【数据变动输出 2：异常值剔除后数据】
    step2_path = os.path.join(output_dir, 'Step2_Outliers_Removed.csv')
    merged_df.to_csv(step2_path)
    print(f"  -> [输出 2] 快照已保存至: Step2_Outliers_Removed.csv\n")

    print("4. 正在利用局部多项式插值与平滑重构进行缺失值补全(解决高低频代差)...")
    total_missing_filled = 0
    total_valid_features = 0

    for col in features:
        if col in merged_df.columns:
            total_points = len(merged_df[col])
            # 插值前统计该列有多少个缺失值
            missing_count_before = merged_df[col].isna().sum()

            # 只有在非 100% 空列（即存在有效数据）的情况下才进行插值与平滑
            if missing_count_before < total_points:
                # 使用多项式插值与平滑均值填补 NaN，解决高低频代差
                merged_df[col] = merged_df[col].interpolate(method='polynomial', order=2)
                merged_df[col] = merged_df[col].bfill().ffill()
                merged_df[col] = merged_df[col].rolling(window=3, min_periods=1, center=True).mean()

                # 插值后再次统计，计算成功补全的数量
                missing_count_after = merged_df[col].isna().sum()
                filled_count = missing_count_before - missing_count_after

                if filled_count > 0:
                    fill_rate = (filled_count / total_points) * 100
                    print(f"    - [重构日志] 特征 '{col:<20}': 成功插补空洞 {filled_count:<4} 个, 填补占比: {fill_rate:.2f}%")
                    total_missing_filled += filled_count
                total_valid_features += 1
            else:
                # 对于因为表头错位等原因导致 100% 缺失的废列，不做处理，留给下一步的 dropna 剔除
                pass

    if total_points > 0 and total_valid_features > 0:
        overall_fill_rate = (total_missing_filled / (total_points * total_valid_features)) * 100
        print(f"  -> [统计] 平滑重构完成！全局共计插值补全缺失数据 {total_missing_filled} 个，整体填补率: {overall_fill_rate:.2f}%")

    # 【数据变动输出 3：平滑重构后数据】
    step3_path = os.path.join(output_dir, 'Step3_Interpolated.csv')
    merged_df.to_csv(step3_path)
    print(f"  -> [输出 3] 缺失值平滑重构完成！快照已保存至: Step3_Interpolated.csv\n")

    return merged_df


def data_discovery_and_normalization(df, output_dir, target_col='al2o3_liquid'):
    """
    第二阶段：基于互信息(MI)的数据发现与特征筛选
    """
    print("=" * 60)
    print("第二阶段：基于互信息(MI)的数据发现与特征归一化")
    print("=" * 60)

    print("1. 正在剔除残余空列与空行...")
    # 先剔除因为表头错位等原因导致 100% 缺失的废列
    df.dropna(axis=1, how='all', inplace=True)
    df.dropna(inplace=True)

    if target_col not in df.columns:
        print(f"警告：未找到目标列 '{target_col}'，将默认使用最后一种指标 '{df.columns[-1]}' 作为靶点。")
        target_col = df.columns[-1]

    feature_cols = [col for col in df.columns if col != target_col]
    X = df[feature_cols]
    y = df[target_col]

    # 【数据变动输出 4：MI 计算前纯净数据】
    step4_path = os.path.join(output_dir, 'Step4_Cleaned_Ready_For_MI.csv')
    df.to_csv(step4_path)
    print(f"  -> [输出 4] 纯净无空值数据集准备完毕！快照已保存至: Step4_Cleaned_Ready_For_MI.csv")

    print("\n2. 正在执行互信息(MI)特征价值计算...")
    mi_scores = mutual_info_regression(X, y, random_state=42)
    mi_series = pd.Series(mi_scores, index=feature_cols).sort_values(ascending=False)
    mi_cumsum = mi_series.cumsum() / mi_series.sum()

    print("\n=================  变量互信息(MI)价值排行 ==================")
    print(f"{'排名':<5} | {'工艺变量':<25} | {'互信息得分 (MI)':<15} | {'累积贡献率'}")
    print("-" * 65)
    for i, (feat, score) in enumerate(mi_series.items(), 1):
        cumsum_val = mi_cumsum[feat]
        print(f"No.{i:<2} | {feat:<25} | {score:<15.4f} | {cumsum_val:.2%}")
    print("==============================================================\n")

    # 选取累计贡献率85%以上的关键特征，保底选取前 6 个
    selected_features = mi_cumsum[mi_cumsum <= 0.85].index.tolist()
    if len(selected_features) < 6:
        safe_count = min(6, len(feature_cols))
        selected_features = mi_series.head(safe_count).index.tolist()

    print(f"根据《选题报告》85%贡献率准则，最终筛出 {len(selected_features)} 个关键变量参与后续增强。")

    # 组装筛选后的数据集
    final_columns = selected_features + [target_col]
    df_selected = df[final_columns]

    # 【数据变动输出 5：互信息降维后数据】
    step5_path = os.path.join(output_dir, 'Step5_MI_Selected_Features.csv')
    df_selected.to_csv(step5_path)
    print(f"  -> [输出 5] 数据降维完成！快照已保存至: Step5_MI_Selected_Features.csv")

    print("\n3. 正在对特征矩阵进行 MinMaxScaler 归一化处理...")
    scaler = MinMaxScaler()
    df_normalized = pd.DataFrame(
        scaler.fit_transform(df_selected),
        columns=df_selected.columns,
        index=df_selected.index
    )

    # 【数据变动输出 6：最终GAN输入数据】
    step6_path = os.path.join(output_dir, 'Step6_TimeGAN_Ready_Dataset.csv')
    df_normalized.to_csv(step6_path)

    print(f"  -> [输出 6] 归一化完成！数据维度: {df_normalized.shape}。")
    print(f"  -> TimeGAN 最终专用数据集已保存至: Step6_TimeGAN_Ready_Dataset.csv")
    print("=" * 60)
    print("🎉 全流程执行完毕，随时可送入 TimeGAN 网络进行数据增强！")

    return df_normalized, scaler


# ==========================================
# 第三阶段：TimeGAN 数据增强模块 (核心更新区)
# ==========================================
class DualGRU_Network(nn.Module):
    """ 双层GRU骨干网络 (满足《选题报告》要求) """
    def __init__(self, input_dim, hidden_dim, out_dim, num_layers=2, use_sigmoid=False):
        super(DualGRU_Network, self).__init__()
        self.gru = nn.GRU(input_dim, hidden_dim, num_layers=num_layers, batch_first=True)
        self.linear = nn.Linear(hidden_dim, out_dim)
        self.use_sigmoid = use_sigmoid  # 新增控制位
        self.sigmoid = nn.Sigmoid()     # 引入 Sigmoid 将输出强制压在 0~1 之间

    def forward(self, x):
        out, _ = self.gru(x)
        out = self.linear(out)
        if self.use_sigmoid:
            out = self.sigmoid(out)
        return out


def physical_mechanism_loss(generated_data_norm, feature_cols, scaler, device):
    """
    【核心创新点更新】融合最新文献与《选题报告》的拜耳法物理机理约束
    注意：神经网络生成的 generated_data_norm 处于 [1] 归一化区间，
    必须将其“可微地”反归一化到真实物理量纲，才能代入化学反应平衡方程式！
    """
    # 1. 提取 MinMaxScaler 的参数，转换为支持梯度的 Tensor
    mins = torch.tensor(scaler.data_min_, dtype=torch.float32, device=device)
    ranges = torch.tensor(scaler.data_range_, dtype=torch.float32, device=device)

    # 2. 可微反归一化 (X_real = X_norm * range + min)
    gen_real = generated_data_norm * ranges + mins

    # 初始化为可求导的 PyTorch 张量
    penalty = torch.tensor(0.0, device=device)

    # 定义获取索引的安全函数
    def get_idx(name_substring):
        return next((i for i, col in enumerate(feature_cols) if name_substring in col), None)

    # -------------------------------------------------------------
    # 物理约束 A：液相拜耳法反应平衡定律 (苛性比值 Ak 约束)
    # 公式: Ak = 1.645 * Na2Ok / Al2O3
    # -------------------------------------------------------------
    na2ok_idx = get_idx('na2ok_value')
    al2o3_liq_idx = get_idx('al2o3_liquid')
    ak_idx = get_idx('ak_value')

    if na2ok_idx is not None and al2o3_liq_idx is not None and ak_idx is not None:
        na2ok = gen_real[:, :, na2ok_idx]
        al2o3 = gen_real[:, :, al2o3_liq_idx]
        ak_real = gen_real[:, :, ak_idx]

        # 1. 守恒方程均方误差：生成的指标间必须符合化学公式
        ak_calc = 1.645 * na2ok / (al2o3 + 1e-6)
        penalty += 10.0 * torch.mean((ak_real - ak_calc) ** 2)

        # 2. 根据文献防结垢的工业安全界限约束 (Ak < 1.30 易析出结垢，Ak > 1.45 能耗过高)
        penalty += 5.0 * torch.mean(torch.relu(1.30 - ak_real))  # 低于下限惩罚
        penalty += 5.0 * torch.mean(torch.relu(ak_real - 1.45))  # 高于上限惩罚

    # -------------------------------------------------------------
    # 物理约束 B：液相物料守恒 (碳碱比 Nc/Nt)
    # 公式: Nc_Nt = Nc / Na2Ot
    # -------------------------------------------------------------
    nc_idx = get_idx('nc_value')
    na2ot_idx = get_idx('na2ot_value')
    nc_nt_idx = get_idx('nc_nt_value')

    if nc_idx is not None and na2ot_idx is not None and nc_nt_idx is not None:
        nc = gen_real[:, :, nc_idx]
        na2ot = gen_real[:, :, na2ot_idx]
        nc_nt_real = gen_real[:, :, nc_nt_idx]

        nc_nt_calc = nc / (na2ot + 1e-6)
        penalty += 10.0 * torch.mean((nc_nt_real - nc_nt_calc) ** 2)

    # -------------------------------------------------------------
    # 物理约束 C：固相质量守恒与脱硅产物(DSP)成分约束
    # 公式1: 铝硅比 A/S = Al2O3 / SiO2
    # 公式2: 钙硅比 C/S = CaO / SiO2
    # -------------------------------------------------------------
    al2o3_sol_idx = get_idx('al2o3_value')
    sio2_idx = get_idx('sio2_value')
    cao_idx = get_idx('ca_o_value')
    a_s_idx = get_idx('a_s_value')
    c_s_idx = get_idx('c_s_value')

    if sio2_idx is not None:
        sio2 = gen_real[:, :, sio2_idx]

        # 铝硅比验证
        if al2o3_sol_idx is not None and a_s_idx is not None:
            a_s_calc = gen_real[:, :, al2o3_sol_idx] / (sio2 + 1e-6)
            penalty += 10.0 * torch.mean((gen_real[:, :, a_s_idx] - a_s_calc) ** 2)

        # 钙硅比验证
        if cao_idx is not None and c_s_idx is not None:
            c_s_calc = gen_real[:, :, cao_idx] / (sio2 + 1e-6)
            penalty += 10.0 * torch.mean((gen_real[:, :, c_s_idx] - c_s_calc) ** 2)

    # -------------------------------------------------------------
    # 物理约束 D：固含与流变学基础界限 (Bingham流体不可能存在负固含)
    # -------------------------------------------------------------
    solid_content_idx = get_idx('solid_content_value_liquid')
    if solid_content_idx is not None:
        sc = gen_real[:, :, solid_content_idx]
        # 注意这里：改成 penalty = penalty + ... 防止原地操作报错
        penalty = penalty + 10.0 * torch.mean(torch.relu(-sc))# 强力惩罚负数


    # -------------------------------------------------------------
    # 物理约束 E：全局非负性基底约束 (质量守恒的最基本前提)
    # 工业生产中，任何物质的浓度、温度、流量都不可能存在负值
    # -------------------------------------------------------------
    # gen_real 的形状是 (batch_size, seq_len, input_dim)
    # 我们对所有生成的真实物理量进行扫描，只要小于 0 就施加严厉惩罚
    global_negative_penalty = 10.0 * torch.mean(torch.relu(-gen_real))
    penalty = penalty + global_negative_penalty

    return penalty


def timegan_data_augmentation(df_selected, output_dir, seq_len=24, epochs=100):
    """
    基于物理规律约束的 TimeGAN
    """
    print("=" * 60)
    print("第三阶段：基于TimeGAN的工业数据增强 (深度融合拜耳法物理约束)")
    print("=" * 60)

    # 设备检查：自动调度 RTX 3060
    device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
    print(f"正在使用算力设备: {device}")

    feature_cols = df_selected.columns.tolist()
    input_dim = len(feature_cols)
    hidden_dim = 64
    latent_dim = 24

    # 数据归一化 (MinMaxScaler)
    scaler = MinMaxScaler()
    scaled_data = scaler.fit_transform(df_selected.values)

    # 构造滑动窗口样本
    data_windows = np.array([scaled_data[i:i + seq_len] for i in range(len(scaled_data) - seq_len)])
    original_sample_size = len(df_selected)
    target_gen_size = int(original_sample_size * 2.0)  # 满足生成 200% 要求

    # 实例化四个双层GRU骨干网络并放到GPU
    embedder = DualGRU_Network(input_dim, hidden_dim, latent_dim, num_layers=2).to(device)
    recovery = DualGRU_Network(latent_dim, hidden_dim, input_dim, num_layers=2, use_sigmoid=True).to(device)
    generator = DualGRU_Network(input_dim, hidden_dim, latent_dim, num_layers=2).to(device)
    discriminator = DualGRU_Network(latent_dim, hidden_dim, 1, num_layers=2).to(device)

    e_opt = optim.Adam(list(embedder.parameters()) + list(recovery.parameters()), lr=0.001)
    g_opt = optim.Adam(generator.parameters(), lr=0.001)
    d_opt = optim.Adam(discriminator.parameters(), lr=0.001)

    dataset = TensorDataset(torch.FloatTensor(data_windows).to(device))
    dataloader = DataLoader(dataset, batch_size=128, shuffle=True)

    print("开始进行对抗网络训练...")
    for epoch in range(epochs):
        for batch in dataloader:
            X_real = batch[0]
            batch_sz = X_real.size(0)
            Z = torch.randn(batch_sz, seq_len, input_dim, device=device)

            # 前向计算
            H = embedder(X_real)
            X_tilde = recovery(H)
            E_hat = generator(Z)
            X_hat = recovery(E_hat)

            # [重点修复 3] 兜底防线：计算物理损失前，强制将可能由于浮点精度造成的微小越界硬截断
            X_hat = torch.clamp(X_hat, min=0.0, max=1.0)
            X_tilde = torch.clamp(X_tilde, min=0.0, max=1.0)

            # 加上 .detach()，截断梯度回传，保护 embedder 不被判别器损失干扰
            Y_real = discriminator(H.detach())
            Y_fake = discriminator(E_hat.detach())

            # 损失函数基础部分
            recon_loss = nn.MSELoss()(X_real, X_tilde)
            d_loss = nn.BCEWithLogitsLoss()(Y_real, torch.ones_like(Y_real)) + \
                     nn.BCEWithLogitsLoss()(Y_fake, torch.zeros_like(Y_fake))
            g_adv_loss = nn.BCEWithLogitsLoss()(discriminator(E_hat), torch.ones_like(Y_fake))

            # --- 【调用最新更新的拜耳法物理机理约束】 ---
            phys_loss = physical_mechanism_loss(X_hat, feature_cols, scaler, device)

            # 生成器总损失 = 对抗损失 + 物理约束惩罚
            g_loss = g_adv_loss + 1.0 * phys_loss

            # 反向传播优化：先统一清空梯度
            e_opt.zero_grad()
            d_opt.zero_grad()
            g_opt.zero_grad()

            # 先统一进行反向传播计算梯度（此时参数还未被修改，绝对安全）
            recon_loss.backward(retain_graph=True)
            d_loss.backward(retain_graph=True)  # 加上 retain_graph=True 防止图被提前释放
            g_loss.backward()

            # 梯度全部算完后，最后统一更新网络权重
            e_opt.step()
            d_opt.step()
            g_opt.step()

        if (epoch + 1) % 10 == 0:
            print(
                f"Epoch {epoch + 1}/{epochs} | D Loss: {d_loss.item():.4f} | G Loss: {g_adv_loss.item():.4f} | Phys Loss (物理违规惩罚): {phys_loss.item():.4f}")

    # 生成合成数据
    print(f"正在自主合成 {target_gen_size} 条符合物料守恒定律的高质量样本...")
    with torch.no_grad():
        Z_new = torch.randn(target_gen_size, seq_len, input_dim, device=device)
        E_new = generator(Z_new)
        X_generated = recovery(E_new)

        # 反归一化前，再次使用 clamp 确保存入的数据严格处于 0~1
        X_generated = torch.clamp(X_generated, min=0.0, max=1.0)

    # 提取序列特征最后一步降维
    generated_data = X_generated[:, -1, :].cpu().numpy()

    # 逆归一化并存入 DataFrame
    generated_data_rescaled = scaler.inverse_transform(generated_data)
    df_generated = pd.DataFrame(generated_data_rescaled, columns=feature_cols)

    # 【终极硬约束】：强行将所有小于 0 的非理性物理值截断为 0
    df_generated = df_generated.clip(lower=0.0)

    df_augmented = pd.concat([df_selected, df_generated], axis=0).reset_index(drop=True)
    output_path = os.path.join(output_dir, 'augmented_dataset_physics_infused.csv')
    df_augmented.to_csv(output_path, index=False, encoding='utf-8-sig')

    print(f"增强完成！合成废样比率已控制。数据已保存至: {output_path}")
    return df_augmented


