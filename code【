# ---------------------------------------------------------
# 验证模块辅助函数：将二维数据转换为CNN需要的三维时序序列
# ---------------------------------------------------------
def create_sequences(data_array, seq_len, target_idx):
    X, y = [], []
    for i in range(len(data_array) - seq_len):
        X.append(data_array[i: i + seq_len, :])
        y.append(data_array[i + seq_len - 1, target_idx])
    return np.array(X), np.array(y)


# ---------------------------------------------------------
# 验证模块辅助函数：生成随机噪声增强样本 (补齐对照组)
# ---------------------------------------------------------
def generate_random_noise_samples(X_seq, y_seq, noise_factor=0.03):
    noise = np.random.normal(0, noise_factor, X_seq.shape)
    X_noisy = X_seq + noise
    X_noisy = np.clip(X_noisy, 0.0, 1.0)  # 保证噪声加入后不会物理越界
    return X_noisy, y_seq


# ---------------------------------------------------------
# 验证模块核心：1D-CNN 预测器网络
# ---------------------------------------------------------
class CNN1D_Predictor(nn.Module):
    def __init__(self, input_dim, seq_len):
        super(CNN1D_Predictor, self).__init__()
        self.conv1 = nn.Conv1d(input_dim, 32, kernel_size=5, padding=2)
        self.relu1 = nn.ReLU()
        self.pool1 = nn.MaxPool1d(kernel_size=2)

        self.conv2 = nn.Conv1d(32, 64, kernel_size=3, padding=1)
        self.relu2 = nn.ReLU()

        self.conv3 = nn.Conv1d(64, 128, kernel_size=3, padding=1)
        self.relu3 = nn.ReLU()

        self.dropout = nn.Dropout(p=0.2)
        flattened_size = 128 * (seq_len // 2)
        self.fc = nn.Linear(flattened_size, 1)

    def forward(self, x):
        x = x.transpose(1, 2)
        x = self.pool1(self.relu1(self.conv1(x)))
        x = self.relu3(self.conv3(self.relu2(self.conv2(x))))
        x = self.dropout(x)
        x = x.reshape(x.size(0), -1)
        return self.fc(x)


# ---------------------------------------------------------
# 验证模块核心：统一评估管线
# ---------------------------------------------------------
def evaluate_cnn_model(train_X, train_y, test_X, test_y, model_name="Baseline", epochs=50, batch_size=64):
    device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
    input_dim = train_X.shape[2]
    seq_len = train_X.shape[1]

    model = CNN1D_Predictor(input_dim, seq_len).to(device)
    criterion = nn.MSELoss()
    optimizer = optim.Adam(model.parameters(), lr=0.001)

    train_loader = DataLoader(TensorDataset(torch.FloatTensor(train_X), torch.FloatTensor(train_y)),
                              batch_size=batch_size, shuffle=True)

    print(f"  -> [{model_name}] 正在执行训练...")
    model.train()
    for epoch in range(epochs):
        for batch_x, batch_y in train_loader:
            batch_x, batch_y = batch_x.to(device), batch_y.to(device)
            optimizer.zero_grad()
            outputs = model(batch_x).squeeze()
            loss = criterion(outputs, batch_y)
            loss.backward()
            optimizer.step()

    model.eval()
    with torch.no_grad():
        test_X_tensor = torch.FloatTensor(test_X).to(device)
        predictions = model(test_X_tensor).squeeze().cpu().numpy()
        trues = test_y

    rmse = np.sqrt(mean_squared_error(trues, predictions))
    mae = mean_absolute_error(trues, predictions)
    mape = np.mean(np.abs((trues - predictions) / (trues + 1e-8))) * 100
    cv = np.std(np.abs(trues - predictions)) / (np.mean(np.abs(trues - predictions)) + 1e-8)

    print(f"  -> [{model_name}] 评估完毕 | RMSE: {rmse:.4f} | MAE: {mae:.4f} | MAPE: {mape:.2f}% | 残差CV: {cv:.4f}")
    return predictions, trues, rmse, mape, cv


# ---------------------------------------------------------
# 验证模块绘图：定性分析图表
# ---------------------------------------------------------
def plot_tsne_distribution(real_data, generated_data, output_dir):
    print("正在执行 t-SNE 降维特征空间可视化...")
    real_flat = np.mean(real_data, axis=1)
    gen_flat = np.mean(generated_data, axis=1)

    combined_data = np.vstack((real_flat, gen_flat))
    labels = np.array(['Real'] * len(real_flat) + ['TimeGAN'] * len(gen_flat))

    combined_scaled = StandardScaler().fit_transform(combined_data)
    tsne_results = TSNE(n_components=2, perplexity=30, random_state=42).fit_transform(combined_scaled)

    plt.figure(figsize=(8, 6))
    plt.scatter(tsne_results[labels == 'Real', 0], tsne_results[labels == 'Real', 1], c='blue', alpha=0.5,
                label='Real Data', marker='o')
    plt.scatter(tsne_results[labels == 'TimeGAN', 0], tsne_results[labels == 'TimeGAN', 1], c='red', alpha=0.5,
                label='TimeGAN Generated', marker='x')

    plt.title('t-SNE Distribution: Real vs TimeGAN')
    plt.legend()
    plt.grid(True, linestyle='--', alpha=0.6)
    plt.savefig(os.path.join(output_dir, 'tsne_distribution.png'), dpi=300)
    plt.close()


def plot_prediction_curves(trues, pred_base, pred_noise, pred_gan, output_dir):
    plt.figure(figsize=(12, 5))
    plot_len = min(100, len(trues))

    plt.plot(trues[:plot_len], label='True Target', color='black', linewidth=2)
    plt.plot(pred_base[:plot_len], label='Baseline (Small Sample)', color='blue', linestyle='--')
    plt.plot(pred_noise[:plot_len], label='Random Noise Augmented', color='green', linestyle=':')
    plt.plot(pred_gan[:plot_len], label='TimeGAN Augmented', color='red', linestyle='-.')

    plt.title('Prediction Curve Comparison on Independent Test Set')
    plt.legend()
    plt.grid(True, linestyle='--', alpha=0.6)
    plt.savefig(os.path.join(output_dir, 'prediction_fitting_curve.png'), dpi=300)
    plt.close()


