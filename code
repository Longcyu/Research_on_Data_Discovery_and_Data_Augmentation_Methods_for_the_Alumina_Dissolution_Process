    ax.bar(x - width / 2, results["随机噪声增强"], width, label='噪声增强', color='#1f77b4')
    ax.bar(x + width / 2, results["TimeGAN增强"], width, label='TimeGAN增强', color='#ff7f0e')
    ax.set_title('分布一致性理论验证 (指标越低越好)')
    ax.set_xticks(x);
    ax.set_xticklabels(metrics)
    ax.legend()
    plt.tight_layout()
    plt.savefig(os.path.join(output_dir, 'theoretical_validation.png'), dpi=300)
