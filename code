def data_discovery_and_normalization(baseline_df, df_with_nans, target_col, output_dir):
    print("\n" + "=" * 60)
    print("第二阶段：基于先验约束与 HSIC 的非线性特征发现")
    print("=" * 60)

    prior_physical_cols = ['fe2o3_value', 'na2ok_value', 'ak_value', 'solid_content_value']
    candidate_cols = [col for col in baseline_df.columns if col not in prior_physical_cols and col != target_col]

    X_candidates = baseline_df[candidate_cols]
    y = baseline_df[target_col].values

    print(f"1. 加载机理先验特征 {len(prior_physical_cols)} 维，开始对剩余候选变量进行 HSIC 互信息评估...")
    hsic_results = {}
    for col in candidate_cols:
        hsic_results[col] = calculate_hsic(X_candidates[col].values, y)

    hsic_series = pd.Series(hsic_results).sort_values(ascending=False)
    hsic_cumsum = hsic_series.cumsum() / hsic_series.sum()

    print("\n================= 候选变量 HSIC (非线性依赖) 价值排行 =================")
    print(f"{'工艺变量':<25} | {'HSIC 得分':<12} | {'累积贡献率'}")
    print("-" * 65)
    for feat, score in hsic_series.items():
        cumsum_val = hsic_cumsum[feat]
        print(f"{feat:<25} | {score:<12.6f} | {cumsum_val:.2%}")
    print("=======================================================================\n")

    fig, ax1 = plt.subplots(figsize=(10, 6))
    ax2 = ax1.twinx()

    bars = ax1.bar(hsic_series.index, hsic_series.values, color='#4C72B0', alpha=0.8, label='HSIC Score')
    line, = ax2.plot(hsic_cumsum.index, hsic_cumsum.values * 100, color='#C44E52', marker='o', linewidth=2,
                     label='Cumulative Contribution (%)')

    ax2.axhline(y=95, color='gray', linestyle='--', alpha=0.7)
    ax2.text(len(hsic_series) - 1.5, 96, '95% Threshold', color='gray')

    ax1.set_xlabel('Process Variables')
    ax1.set_ylabel('HSIC Score')
    ax2.set_ylabel('Cumulative Contribution (%)')
    ax1.set_xticklabels(hsic_series.index, rotation=45, ha='right')
    plt.title('Pareto Chart of HSIC Feature Importance')
    plt.tight_layout()
    hsic_path = os.path.join(output_dir, 'hsic_pareto_chart.png')
    plt.savefig(hsic_path, dpi=300)
    plt.close()
    print(f"  -> [输出] 论文图表2: HSIC特征帕累托图已保存至: {hsic_path}")

    mask = hsic_cumsum <= 0.95
    if not mask.all():
        cross_idx = mask.argmin()
        data_driven_features = hsic_cumsum.iloc[:cross_idx + 1].index.tolist()
    else:
        data_driven_features = hsic_cumsum.index.tolist()

    final_cols = prior_physical_cols + data_driven_features + [target_col]
    final_cols = list(dict.fromkeys(final_cols))

    baseline_selected = baseline_df[final_cols]
    nans_selected = df_with_nans[final_cols]

    print(f"  -> [成功] 特征清洗与价值发现完毕！")
    print(f"  -> [详情] 机理先验集: {prior_physical_cols}")
    print(f"  -> [详情] 数据驱动集: {data_driven_features}")
    print(f"  -> [详情] 最终保留特征 ({len(final_cols)}维): {final_cols}")

    return baseline_selected, nans_selected, final_cols


