# ==========================================
# 工具函数：计算经验 HSIC (Hilbert-Schmidt Independence Criterion)
# ==========================================
def calculate_hsic(X, Y, sigma=None):
    n = X.shape[0]
    if n > 1000:
        step = n // 1000
        X = X[:1000 * step:step]
        Y = Y[:1000 * step:step]
        n = X.shape[0]

    X = X.reshape(-1, 1) if len(X.shape) == 1 else X
    Y = Y.reshape(-1, 1) if len(Y.shape) == 1 else Y

    K = rbf_kernel(X, gamma=sigma)
    L = rbf_kernel(Y, gamma=sigma)

    H = np.eye(n) - np.ones((n, n)) / n
    K_centered = H @ K @ H
    L_centered = H @ L @ H

    hsic_val = np.trace(K_centered @ L_centered) / ((n - 1) ** 2)
    return hsic_val


# ==========================================
# 第一阶段重构：时空融合、异常检测与遮盖
# ==========================================
def data_preprocessing_pipeline(liquid_path, solid_path, output_dir, target_col='al2o3_liquid'):
    print("=" * 60)
    print("第一阶段：多速率同步对齐与时序连续性保护重构")
    print("=" * 60)

    print("1. 正在读取原始液相与固相工业数据...")
    liquid_df = pd.read_csv(liquid_path, encoding='gb18030', low_memory=False)
    solid_df = pd.read_csv(solid_path, encoding='gb18030', low_memory=False)
    print("  -> [成功] 原始液相与固相工业数据读取完毕！")

    liquid_df['datatime'] = pd.to_datetime(liquid_df['datatime'])
    solid_df['datatime'] = pd.to_datetime(solid_df['datatime'])

    liquid_cols = ['datatime', 'na2ok_value', 'nc_value', 'nc_nt_value', 'al2o3_value',
                   'solid_content_value', 'ak_value', 'na2ot_value']
    solid_cols = ['datatime', 'al2o3_value', 'sio2_value', 'fe2o3_value', 'tio2_value',
                  'na2o_value', 'a_s_value', 'c_s_value', 'n_s_value', 'ca_o_value']

    liquid_df = liquid_df[[c for c in liquid_cols if c in liquid_df.columns]].rename(
        columns={'al2o3_value': 'al2o3_liquid'})
    solid_df = solid_df[[c for c in solid_cols if c in solid_df.columns]].rename(columns={'al2o3_value': 'al2o3_solid'})

    for col in liquid_df.columns:
        if col != 'datatime': liquid_df[col] = pd.to_numeric(liquid_df[col], errors='coerce')
    for col in solid_df.columns:
        if col != 'datatime': solid_df[col] = pd.to_numeric(solid_df[col], errors='coerce')

    print("2. 执行严格 8 小时时间步对齐与时间戳去重...")
    liquid_unique = liquid_df.groupby('datatime').mean()
    solid_unique = solid_df.groupby('datatime').mean()
    liquid_8h = liquid_unique.resample('8H').median()
    solid_8h = solid_unique.resample('8H').median()

    merged_df = pd.merge(liquid_8h, solid_8h, left_index=True, right_index=True, how='outer').sort_index()

    os.makedirs(output_dir, exist_ok=True)
    step1_path = os.path.join(output_dir, 'Step1_Raw_Merged.csv')
    merged_df.to_csv(step1_path)
    print(f"  -> [输出] 刚融合完成的原始数据已保存至：{step1_path}")

    initial_missing_rate = merged_df.isna().sum().sum() / merged_df.size * 100

    print("\n3. 执行基于 Hampel 滤波的动态时序异常脉冲检测...")
    features = [c for c in merged_df.columns if c != 'datatime']
    outlier_mask = pd.DataFrame(False, index=merged_df.index, columns=merged_df.columns)

    total_outliers = 0
    total_points = merged_df.size

    window_size = 5
    n_sigmas = 3
    epsilon = 1e-4

    plot_feature = 'na2o_value' if 'na2o_value' in features else features[0]

    for col in features:
        series = merged_df[col].copy()

        rolling_median = series.rolling(window=window_size, center=True, min_periods=1).median()
        rolling_mad = (series - rolling_median).abs().rolling(window=window_size, center=True, min_periods=1).median()

        robust_mad = np.maximum(rolling_mad, epsilon)

        lower_bound = rolling_median - (n_sigmas * 1.4826 * robust_mad)
        upper_bound = rolling_median + (n_sigmas * 1.4826 * robust_mad)

        mask = (series < lower_bound) | (series > upper_bound)
        outlier_mask[col] = mask

        outliers_count = mask.sum()
        total_outliers += outliers_count
        replace_rate = (outliers_count / len(series)) * 100

        if outliers_count > 0:
            print(f"  - [检测日志] 特征 '{col:<20}': 修正动态异常点 {outliers_count:<4} 个, 替换率: {replace_rate:.2f}%")

        if col == plot_feature:
            plt.figure(figsize=(12, 5))
            plot_len = min(200, len(series))
            x_axis = range(plot_len)
            plt.plot(x_axis, series.iloc[:plot_len], label='Original Signal', color='#4C72B0', alpha=0.8)
            plt.plot(x_axis, lower_bound.iloc[:plot_len], label='Dynamic Lower Bound', color='#C44E52', linestyle='--')
            plt.plot(x_axis, upper_bound.iloc[:plot_len], label='Dynamic Upper Bound', color='#C44E52', linestyle='--')

            outlier_idx = np.where(mask.iloc[:plot_len])[0]
            if len(outlier_idx) > 0:
                plt.scatter(outlier_idx, series.iloc[outlier_idx], color='black', zorder=5, label='Detected Outliers',
                            marker='x')

            plt.title(f'Hampel Dynamic Filtering for Process Variable: {col}')
            plt.xlabel('Time Steps (8H)')
            plt.ylabel('Sensor Value')
            plt.legend()
            plt.tight_layout()
            hampel_path = os.path.join(output_dir, 'hampel_filter_visualization.png')
            plt.savefig(hampel_path, dpi=300)
            plt.close()
            print(f"  -> [输出] 论文图表1: Hampel滤波演示图已保存至: {hampel_path}")

    initial_outlier_rate = total_outliers / merged_df.size * 100
    global_replace_rate = (total_outliers / total_points) * 100

    print(f"  -> [统计] 异常替换完成！全局共计修正飞点 {total_outliers} 个，整体替换率: {global_replace_rate:.4f}%")

    df_with_nans = merged_df.copy()
    df_with_nans[outlier_mask] = np.nan

    print("4. 为计算生成误差，遮盖部分正常的真实目标特征...")
    valid_target_idx = df_with_nans[target_col].dropna().index
    mask_size = max(1, int(len(valid_target_idx) * 0.05))
    test_mask_idx = np.random.choice(valid_target_idx, size=mask_size, replace=False)

    true_masked_data = df_with_nans.loc[test_mask_idx, target_col].copy()
    df_with_nans.loc[test_mask_idx, target_col] = np.nan

    print("5. 使用平滑与插值生成基底数据，用于后续 TimeGAN 预训练...")
    baseline_df = df_with_nans.interpolate(method='linear', limit_direction='both').ffill().bfill()

    print(f"  -> [结构监控] 最终残留缺失值: {baseline_df.isna().sum().sum()} (应趋于0)")

    step3_path = os.path.join(output_dir, 'Step3_Cleaned_8H_Aligned.csv')
    baseline_df.to_csv(step3_path)
    print(f"  -> [输出 1] 重构后的 8h 步长工业数据集已保存：Step3_Cleaned_8H_Aligned.csv")

    return baseline_df, df_with_nans, test_mask_idx, true_masked_data, initial_missing_rate, initial_outlier_rate


