class CNN1D_Classifier(nn.Module):
    def __init__(self, input_dim, seq_len, num_classes=3):
        super(CNN1D_Classifier, self).__init__()
        self.conv1 = nn.Conv1d(input_dim, 64, kernel_size=5, padding=2)
        self.bn1 = nn.BatchNorm1d(64)
        self.relu1 = nn.ReLU()

        self.conv2 = nn.Conv1d(64, 128, kernel_size=3, padding=1)
        self.bn2 = nn.BatchNorm1d(128)
        self.relu2 = nn.ReLU()

        self.conv3 = nn.Conv1d(128, 128, kernel_size=3, padding=1)
        self.bn3 = nn.BatchNorm1d(128)
        self.relu3 = nn.ReLU()

        self.gap = nn.AdaptiveAvgPool1d(1)
        self.dropout = nn.Dropout(p=0.3)
        self.fc = nn.Linear(128, num_classes)

    def forward(self, x):
        x = x.transpose(1, 2)
        x = self.relu1(self.bn1(self.conv1(x)))
        x = self.relu2(self.bn2(self.conv2(x)))
        x = self.relu3(self.bn3(self.conv3(x)))

        x = self.gap(x)
        x = x.view(x.size(0), -1)
        x = self.dropout(x)
        return self.fc(x)


def evaluate_cnn_classifier(train_X, train_y, test_X, test_y, output_dir, model_name="Baseline", epochs=100,
                            batch_size=64):
    device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
    train_X_sub, val_X, train_y_sub, val_y = train_test_split(
        train_X, train_y, test_size=0.1, stratify=train_y, random_state=42
    )

    model = CNN1D_Classifier(train_X.shape[2], train_X.shape[1], num_classes=3).to(device)

    class_counts = np.bincount(train_y_sub)
    total_samples = len(train_y_sub)
    smoothed_weights = np.sqrt(total_samples / (len(class_counts) * class_counts))
    class_weights_tensor = torch.FloatTensor(smoothed_weights).to(device)

    criterion = nn.CrossEntropyLoss(weight=class_weights_tensor)
    optimizer = optim.Adam(model.parameters(), lr=0.002, weight_decay=1e-4)
    scheduler = optim.lr_scheduler.CosineAnnealingLR(optimizer, T_max=epochs, eta_min=1e-6)

    train_loader = DataLoader(
        TensorDataset(torch.FloatTensor(train_X_sub), torch.LongTensor(train_y_sub)),
        batch_size=batch_size, shuffle=True
    )

    best_val_acc = 0.0
    best_model_state = None

    for epoch in range(epochs):
        model.train()
        for batch_x, batch_y in train_loader:
            optimizer.zero_grad()
            outputs = model(batch_x.to(device))
            loss = criterion(outputs, batch_y.to(device))
            loss.backward()
            optimizer.step()
        scheduler.step()

        model.eval()
        with torch.no_grad():
            val_out = model(torch.FloatTensor(val_X).to(device))
            _, val_preds = torch.max(val_out, 1)
            val_acc = accuracy_score(val_y, val_preds.cpu().numpy())
            if val_acc >= best_val_acc:
                best_val_acc = val_acc
                best_model_state = model.state_dict().copy()

    model.load_state_dict(best_model_state)
    model.eval()
    with torch.no_grad():
        outputs = model(torch.FloatTensor(test_X).to(device))
        _, predictions = torch.max(outputs, 1)
        predictions = predictions.cpu().numpy()

    acc = accuracy_score(test_y, predictions) * 100
    print(f"  -> [{model_name}] 测试集诊断准确率: {acc:.2f}%")

    cm = confusion_matrix(test_y, predictions, labels=[0, 1, 2])
    global_cm_results.append(cm)

    display_names = {
        "Original_Imputed_Sample": "基准小样本组",
        "Random_Noise_Augmented": "随机噪声增强组",
        "TimeGAN_Enhanced": "TimeGAN机理增强组"
    }
    global_cm_names.append(display_names.get(model_name, model_name))

    return predictions, test_y, acc


