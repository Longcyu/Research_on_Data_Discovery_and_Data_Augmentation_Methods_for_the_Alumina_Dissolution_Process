def get_ak_thresholds(df, ak_col='ak_value'):
    q15 = df[ak_col].quantile(0.15)
    q85 = df[ak_col].quantile(0.85)
    return q15, q85


def generate_labels(df, q15, q85, ak_col='ak_value'):
    vals = df[ak_col].values
    labels = np.zeros(len(vals))
    labels[vals < q15] = 0
    labels[(vals >= q15) & (vals <= q85)] = 1
    labels[vals > q85] = 2
    return labels.astype(int)


def create_sequences_cls(data_array, labels_array, seq_len):
    X, y = [], []
    for i in range(len(data_array) - seq_len + 1):
        X.append(data_array[i: i + seq_len, :])
        y.append(labels_array[i + seq_len - 1])
    return np.array(X), np.array(y)


