class SpectralNorm(nn.Module):
    def __init__(self, module, name='weight', power_iterations=1):
        super(SpectralNorm, self).__init__()
        self.module = module
        self.name = name
        self.power_iterations = power_iterations
        w = getattr(module, name)
        height = w.data.shape[0]
        width = w.data.view(height, -1).shape[1]
        self.register_buffer('u', torch.randn(height, 1))
        self.register_buffer('v', torch.randn(width, 1))

    def forward(self):
        w = getattr(self.module, self.name)
        w_mat = w.view(w.shape[0], -1)
        for _ in range(self.power_iterations):
            self.v = torch.matmul(w_mat.t(), self.u)
            self.v = self.v / (torch.norm(self.v) + 1e-12)
            self.u = torch.matmul(w_mat, self.v)
            self.u = self.u / (torch.norm(self.u) + 1e-12)
        sigma = torch.sum(self.u * torch.matmul(w_mat, self.v))
        w_normalized = w / (sigma + 1e-12)
        return w_normalized

    def set_weight(self):
        setattr(self.module, self.name, nn.Parameter(self.forward()))


class DualGRU_Discriminator(nn.Module):
    def __init__(self, input_dim, hidden_dim, num_layers=2):
        super(DualGRU_Discriminator, self).__init__()
        self.gru = nn.GRU(input_dim, hidden_dim, num_layers=num_layers, batch_first=True)
        self.linear = nn.Linear(hidden_dim, 1)
        self.sn = SpectralNorm(self.linear, name='weight', power_iterations=1)

    def forward(self, x):
        out, _ = self.gru(x)
        self.sn.set_weight()
        out = self.linear(out[:, -1, :])
        return out


class DualGRU_Network(nn.Module):
    def __init__(self, input_dim, hidden_dim, out_dim, num_layers=2, use_sigmoid=True):
        super(DualGRU_Network, self).__init__()
        self.gru = nn.GRU(input_dim, hidden_dim, num_layers=num_layers, batch_first=True)
        self.linear = nn.Linear(hidden_dim, out_dim)
        self.use_sigmoid = use_sigmoid
        self.sigmoid = nn.Sigmoid()

    def forward(self, x):
        out, _ = self.gru(x)
        out = self.linear(out)
        if self.use_sigmoid:
            out = self.sigmoid(out)
        return out


def compute_gradient_penalty(discriminator, real_data, fake_data, device, lambda_gp=10.0):
    batch_size = real_data.size(0)
    alpha = torch.rand(batch_size, 1, 1, device=device, requires_grad=False)
    alpha = alpha.expand_as(real_data)
    interpolates = alpha * real_data + (1 - alpha) * fake_data
    interpolates.requires_grad_(True)
    with torch.backends.cudnn.flags(enabled=False):
        with torch.cuda.amp.autocast():
            d_interpolates = discriminator(interpolates)
    fake = torch.ones(d_interpolates.size(), device=device, requires_grad=False)
    gradients = torch.autograd.grad(
        outputs=d_interpolates, inputs=interpolates, grad_outputs=fake,
        create_graph=True, retain_graph=True, only_inputs=True,
    )[0].reshape(batch_size, -1)
    return lambda_gp * ((torch.norm(gradients, p=2, dim=1) - 1.0) ** 2).mean()


def compute_temporal_smoothness_loss(generated_data):
    if generated_data.size(1) > 1:
        diff = generated_data[:, 1:, :] - generated_data[:, :-1, :]
        loss_smooth = torch.mean(torch.norm(diff, p=2, dim=2) ** 2)
        return loss_smooth
    return torch.tensor(0.0, device=generated_data.device)


class AdaptivePhysicalLoss:
    def __init__(self, total_epochs, warmup_ratio=0.2, target_weight=1.0):
        self.total_epochs = total_epochs
        self.warmup_epochs = int(total_epochs * warmup_ratio)
        self.transition_epochs = int(total_epochs * 0.3)
        self.target_weight = target_weight

    def get_weight(self, epoch):
        if epoch < self.warmup_epochs:
            return 0.0
        elif epoch < self.warmup_epochs + self.transition_epochs:
            return ((epoch - self.warmup_epochs) / self.transition_epochs) * self.target_weight
        else:
            return self.target_weight


class ModeCollapseDetector:
    def __init__(self, window_size=50):
        self.window_size = window_size
        self.real_vars = []
        self.fake_vars = []
        self.d_loss_history = []

    def detect(self, real_data, fake_data, d_loss):
        self.real_vars.append(np.var(real_data, axis=0).mean())
        self.fake_vars.append(np.var(fake_data, axis=0).mean())
        self.d_loss_history.append(d_loss)
        if len(self.real_vars) < self.window_size: return False, 0.0
        var_ratio = np.mean(self.fake_vars[-self.window_size:]) / (np.mean(self.real_vars[-self.window_size:]) + 1e-6)
        d_loss_std = np.std(self.d_loss_history[-self.window_size:])
        is_collapsed = var_ratio < 0.3 or d_loss_std < 0.01
        severity = min(1.0, (1 - var_ratio) * 0.5 + (0.01 - d_loss_std) * 50)
        return is_collapsed, severity


def physical_mechanism_loss(generated_data_norm, feature_cols, scaler, device):
    mins = torch.tensor(scaler.data_min_, dtype=torch.float32, device=device)
    ranges = torch.tensor(scaler.data_range_, dtype=torch.float32, device=device)

    generated_data_norm_clamped = torch.clamp(generated_data_norm, min=0.0, max=1.0)
    gen_real = generated_data_norm_clamped * ranges + mins

    penalty = torch.tensor(0.0, device=device, requires_grad=True)

    def get_idx(name):
        return next((i for i, col in enumerate(feature_cols) if name in col), None)

    na2ok_idx, al2o3_liq_idx, ak_idx = get_idx('na2ok'), get_idx('al2o3_liquid'), get_idx('ak_value')
    if na2ok_idx is not None and al2o3_liq_idx is not None and ak_idx is not None:
        ak_calc = 1.645 * gen_real[:, :, na2ok_idx] / (gen_real[:, :, al2o3_liq_idx] + 1e-6)
        penalty = penalty + 2.0 * torch.mean(torch.log1p(torch.abs(gen_real[:, :, ak_idx] - ak_calc) + 1e-8))
        penalty = penalty + 1.0 * torch.mean(torch.log1p(torch.relu(1.30 - gen_real[:, :, ak_idx])))
        penalty = penalty + 1.0 * torch.mean(torch.log1p(torch.relu(gen_real[:, :, ak_idx] - 1.45)))

    solid_content_idx = get_idx('solid_content_value')
    if solid_content_idx is not None:
        penalty = penalty + 1.0 * torch.mean(torch.relu(-gen_real[:, :, solid_content_idx]))

    return penalty + 1.0 * torch.mean(torch.relu(-gen_real))


def pretrain_autoencoder(embedder, recovery, train_windows, device, epochs=50, batch_size=128):
    print("\n" + "=" * 60)
    print("【预训练阶段】独立训练 Autoencoder (纯重构损失)")
    print("=" * 60)
    ae_optimizer = optim.Adam(list(embedder.parameters()) + list(recovery.parameters()), lr=0.001)
    ae_criterion = nn.MSELoss()
    dataset = TensorDataset(torch.FloatTensor(train_windows).to(device))
    dataloader = DataLoader(dataset, batch_size=batch_size, shuffle=True)

    embedder.train()
    recovery.train()
    best_loss = float('inf')

    for epoch in range(epochs):
        total_loss = 0.0
        for batch in dataloader:
            X_batch = batch[0]
            recon_loss = ae_criterion(X_batch, recovery(embedder(X_batch)))
            ae_optimizer.zero_grad()
            recon_loss.backward()
            ae_optimizer.step()
            total_loss += recon_loss.item()
        avg_loss = total_loss / len(dataloader)
        if (epoch + 1) % 5 == 0: print(f"  Autoencoder 预训练 Epoch {epoch + 1}/{epochs} | Recon Loss: {avg_loss:.6f}")
        if avg_loss < best_loss: best_loss = avg_loss

    print(f"✓ Autoencoder 预训练完毕！最终重构损失: {best_loss:.6f}\n")
    return embedder, recovery


def timegan_training_imputation_augmentation(
        baseline_scaled, nans_selected, scaler, feature_cols,
        test_mask_idx, true_masked_data,
        init_missing_rate, init_outlier_rate,
        target_col, output_dir, seq_len=24, epochs=800, target_phys_weight=1.0):
    print("\n" + "=" * 60)
    print("第三阶段：使用 TimeGAN 替换基底数据进行插补与增强")
    print("=" * 60)

    device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
    input_dim = len(feature_cols)
    hidden_dim = 128
    latent_dim = 24

    scaled_data = baseline_scaled.values
    data_windows = np.array([scaled_data[i:i + seq_len] for i in range(len(scaled_data) - seq_len + 1)])

    train_limit = int(len(data_windows) * 0.85)
    train_windows = data_windows[:train_limit]

    embedder = DualGRU_Network(input_dim, hidden_dim, latent_dim, num_layers=2).to(device)
    recovery = DualGRU_Network(latent_dim, hidden_dim, input_dim, num_layers=2, use_sigmoid=True).to(device)
    generator = DualGRU_Network(input_dim, hidden_dim, latent_dim, num_layers=2).to(device)
    discriminator = DualGRU_Discriminator(latent_dim, hidden_dim, num_layers=2).to(device)

    embedder, recovery = pretrain_autoencoder(embedder, recovery, train_windows, device, epochs=50, batch_size=128)

    embedder.train()
    recovery.train()
    generator.train()
    discriminator.train()

    ae_optimizer = optim.Adam(list(embedder.parameters()) + list(recovery.parameters()), lr=0.0002, betas=(0.5, 0.999))
    g_optimizer = optim.Adam(generator.parameters(), lr=0.0002, betas=(0.5, 0.999))
    d_optimizer = optim.Adam(discriminator.parameters(), lr=0.0002, betas=(0.5, 0.999))

    scaler_d = torch.cuda.amp.GradScaler()
    scaler_g = torch.cuda.amp.GradScaler()
    scaler_ae = torch.cuda.amp.GradScaler()

    dataset = TensorDataset(torch.FloatTensor(train_windows).to(device))
    dataloader = DataLoader(dataset, batch_size=64, shuffle=True, drop_last=True)

    adaptive_phys_loss = AdaptivePhysicalLoss(epochs, warmup_ratio=0.2, target_weight=target_phys_weight)
    mode_detector = ModeCollapseDetector(window_size=50)

    print(f"\n【Warm-up 预热】前 {adaptive_phys_loss.warmup_epochs} 个 Epoch 将关闭物理约束")
    print("对抗网络防泄漏独立域训练开始...\n")

    hist_epochs = []
    hist_d_loss, hist_g_loss, hist_p_loss, hist_acc = [], [], [], []
    true_masked_clean = true_masked_data.values

    for epoch in range(epochs):
        phys_weight = adaptive_phys_loss.get_weight(epoch)
        for batch_idx, batch in enumerate(dataloader):
            X_real = batch[0]
            batch_sz = X_real.size(0)

            # 1. Discriminator
            d_optimizer.zero_grad()
            with torch.cuda.amp.autocast():
                Z = torch.randn(batch_sz, seq_len, input_dim, device=device)
                H, E_hat = embedder(X_real).detach(), generator(Z).detach()
                d_loss = torch.mean(discriminator(E_hat)) - torch.mean(discriminator(H)) + compute_gradient_penalty(
                    discriminator, H, E_hat, device)
            scaler_d.scale(d_loss).backward()
            scaler_d.step(d_optimizer)
            scaler_d.update()

            # 2. Autoencoder
            ae_optimizer.zero_grad()
            with torch.cuda.amp.autocast():
                recon_loss = nn.MSELoss()(X_real, torch.clamp(recovery(embedder(X_real)), min=0.0, max=1.0))
            scaler_ae.scale(recon_loss).backward()
            scaler_ae.step(ae_optimizer)
            scaler_ae.update()

            # 3. Generator
            if (batch_idx + 1) % 5 == 0 or (batch_idx + 1) == len(dataloader):
                g_optimizer.zero_grad()
                with torch.cuda.amp.autocast():
                    E_hat_new = generator(torch.randn(batch_sz, seq_len, input_dim, device=device))
                    g_adv_loss = -torch.mean(discriminator(E_hat_new))
                    X_fake = recovery(E_hat_new)
                    phys_loss = physical_mechanism_loss(torch.clamp(X_fake, 0.0, 1.0), feature_cols,
                                                        scaler, device) if phys_weight > 0 else torch.tensor(0.0)
                    smooth_loss = compute_temporal_smoothness_loss(E_hat_new)

                    mean_real = torch.mean(X_real, dim=0)
                    var_real = torch.var(X_real, dim=0, unbiased=False)
                    mean_fake = torch.mean(X_fake, dim=0)
                    var_fake = torch.var(X_fake, dim=0, unbiased=False)

                    moment_matching_loss = torch.mean(torch.abs(mean_real - mean_fake)) + torch.mean(
                        torch.abs(var_real - var_fake))
                    g_loss = g_adv_loss + phys_weight * phys_loss + (0.5 * smooth_loss) + (0.5 * moment_matching_loss)
                scaler_g.scale(g_loss).backward()
                scaler_g.step(g_optimizer)
                scaler_g.update()

        if (epoch + 1) % 50 == 0:
            embedder.eval()
            generator.eval()
            recovery.eval()
            with torch.no_grad(), torch.cuda.amp.autocast():
                is_collapsed, severity = mode_detector.detect(
                    embedder(torch.FloatTensor(train_windows[:256]).to(device)).cpu().numpy(),
                    generator(torch.randn(256, seq_len, input_dim, device=device)).cpu().numpy(), d_loss.item())

                X_recon_tmp = recovery(embedder(torch.FloatTensor(data_windows).to(device))).cpu().numpy()
                recon_flat = np.zeros_like(scaled_data)
                recon_flat[:seq_len] = X_recon_tmp[0]
                if len(X_recon_tmp) > 1: recon_flat[seq_len:] = X_recon_tmp[1:, -1, :]
                df_tmp = pd.DataFrame(scaler.inverse_transform(recon_flat), columns=feature_cols,
                                      index=baseline_scaled.index)
                preds_tmp = df_tmp.loc[test_mask_idx, target_col].values
                err_sum = np.sum(np.abs(preds_tmp - true_masked_clean))
                true_sum = np.sum(np.abs(true_masked_clean)) + 1e-4
                acc_tmp = max(0.0, 100.0 - (err_sum / true_sum) * 100)

            embedder.train()
            generator.train()
            recovery.train()
            print(f"Epoch {epoch + 1}/{epochs} | D Loss: {d_loss.item():.4f} | G Loss: {g_adv_loss.item():.4f} | "
                  f"Phys Loss: {phys_loss.item():.4f} | Phys Weight: {phys_weight:.2f} | Acc: {acc_tmp:.2f}% | ✓ 正常")

            hist_epochs.append(epoch + 1)
            hist_d_loss.append(d_loss.item())
            hist_g_loss.append(g_adv_loss.item())
            hist_p_loss.append(phys_loss.item())
            hist_acc.append(acc_tmp)

    print("\n  -> 正在绘制对抗训练与数据补全准确度曲线...")
    fig, axes = plt.subplots(2, 1, figsize=(10, 10))
    axes[0].plot(hist_epochs, hist_d_loss, label='D Loss', color='blue')
    axes[0].plot(hist_epochs, hist_g_loss, label='G Loss', color='orange')
    axes[0].plot(hist_epochs, hist_p_loss, label='Phys Loss', color='green')
    axes[0].set_title('TimeGAN 对抗与机理损失变化曲线')
    axes[0].legend()
    axes[1].plot(hist_epochs, hist_acc, label='Imputation Accuracy (%)', color='red', marker='o')
    axes[1].set_title('数据补全准确度 (1 - WMAPE) 变化曲线')
    axes[1].set_xlabel('Epochs')
    axes[1].set_ylabel('Accuracy (%)')
    axes[1].legend()
    plt.tight_layout()
    curve_path = os.path.join(output_dir, 'training_curves.png')
    plt.savefig(curve_path, dpi=300)
    plt.close()
    print(f"  -> [输出] 论文图表3: 训练曲线图已保存至：{curve_path}")

    # --- 核心插补逻辑 ---
    print("\n利用训练好的 TimeGAN 自动编码器重构全局序列并填补原始 NaNs...")
    embedder.eval()
    recovery.eval()
    with torch.no_grad():
        X_recon = recovery(embedder(torch.FloatTensor(data_windows).to(device))).cpu().numpy()

    reconstructed = np.zeros_like(scaled_data)
    reconstructed[:seq_len] = X_recon[0]
    if len(X_recon) > 1:
        reconstructed[seq_len:] = X_recon[1:, -1, :]

    df_recon = pd.DataFrame(scaler.inverse_transform(reconstructed), columns=feature_cols, index=baseline_scaled.index)

    df_imputed = nans_selected.copy()
    mask_nan = df_imputed.isna()
    df_imputed[mask_nan] = df_recon[mask_nan]

    timegan_preds_clean = df_imputed.loc[test_mask_idx, target_col].values
    error_sum = np.sum(np.abs(timegan_preds_clean - true_masked_clean))
    true_sum = np.sum(np.abs(true_masked_clean)) + 1e-4
    gen_wmape = (error_sum / true_sum) * 100

    gen_rmse = np.sqrt(mean_squared_error(true_masked_clean, timegan_preds_clean))
    gen_mape = mean_absolute_percentage_error(true_masked_clean, timegan_preds_clean) * 100
    gen_cv = (gen_rmse / np.mean(true_masked_clean)) * 100

    outlier_mask_new = pd.DataFrame(False, index=df_imputed.index, columns=df_imputed.columns)
    for col in feature_cols:
        series_orig = nans_selected[col].dropna()
        Q1, Q3 = series_orig.quantile(0.25), series_orig.quantile(0.75)
        IQR = Q3 - Q1
        lower_bound = Q1 - 1.5 * IQR
        upper_bound = Q3 + 1.5 * IQR
        series_imputed = df_imputed[col]
        outlier_mask_new[col] = (series_imputed < lower_bound) | (series_imputed > upper_bound)

    final_outlier_rate = outlier_mask_new.sum().sum() / df_imputed.size * 100
    final_missing_rate = df_imputed.isna().sum().sum() / df_imputed.size * 100

    print("\n  -> 正在绘制 TimeGAN 数据重构误差指标对比图...")
    fig, ax = plt.subplots(figsize=(8, 6))
    metrics_names = ['WMAPE (%)', 'MAPE (%)', 'CV (%)', 'RMSE (Value)']
    metrics_values = [gen_wmape, gen_mape, gen_cv, gen_rmse]
    colors = ['#1f77b4', '#ff7f0e', '#2ca02c', '#d62728']

    bars = ax.bar(metrics_names, metrics_values, color=colors, width=0.5)
    ax.set_title('TimeGAN 数据插补与重构误差多维评估')
    ax.set_ylabel('误差数值 (越低越好)')

    for bar in bars:
        yval = bar.get_height()
        ax.text(bar.get_x() + bar.get_width() / 2, yval + (yval * 0.02), f'{yval:.2f}', ha='center', va='bottom',
                fontsize=10)

    plt.tight_layout()
    imputation_metrics_path = os.path.join(output_dir, 'imputation_error_metrics.png')
    plt.savefig(imputation_metrics_path, dpi=300)
    plt.close()

    target_gen_size = int(len(df_imputed) * 5.5)
    generator.eval()
    with torch.no_grad():
        Z_new = torch.randn(target_gen_size, seq_len, input_dim, device=device)
        X_gen_seqs_scaled = recovery(generator(Z_new)).cpu().numpy()

    return df_imputed, X_gen_seqs_scaled, gen_wmape, discriminator, embedder


